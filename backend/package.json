{
  "name": "three-tier-crud-backend",
  "version": "1.0.0",
  "description": "Production-grade Express.js backend with MongoDB for three-tier CRUD application",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles --testResultsProcessor=jest-sonar-reporter",
    "lint": "echo 'No linter configured'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.5",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-sonar-reporter": "^2.0.0",
    "mongodb-memory-server": "^10.4.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  },
  "jest-sonar-reporter": {
    "outputDirectory": ".",
    "outputName": "test-report.xml"
  }
}
